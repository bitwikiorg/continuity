# Secrets
.secrets/
.env
*.env

# Runtime framework internal

# Logs (keep dir, ignore content)
logs/*.jsonl
logs/*.log
logs/quarantine/

# Snapshots (keep dir, ignore content)
snapshots/*
!snapshots/.gitkeep
!snapshots/ENTRY.template.md

# Archives
archive/

# Completed work (keep dir, ignore content)
completed/*.md
!completed/ENTRY.template.md
!completed/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
venv/
.venv/

# Node
node_modules/

# Knowledge base (keep dir, ignore content)
knowledge/*.md
!knowledge/ENTRY.template.md
!knowledge/.gitkeep

# Hermes auto-injected memories (keep templates, ignore active copies)
memories/*.md
!memories/MEMORY.md
!memories/USER.md

# Site build artifacts
site/node_modules/
site/dist/
